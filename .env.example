# ==================== 自建 RAG - Embedding Provider ====================
# 支持: local (默认，免费本地) | openai | deepseek
EMBEDDING_PROVIDER=local

# OpenAI Embedding
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# DeepSeek Embedding (当 EMBEDDING_PROVIDER=deepseek 时使用)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# ==================== 小米 mimo 大模型 (Chat 层，保持兼容) ====================
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5

NEXT_PUBLIC_MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
NEXT_PUBLIC_MIMO_API_KEY=your_mimo_api_key
NEXT_PUBLIC_MIMO_MODEL=mimo-v2.5

# ==================== Coze Chat (暂时保留，后续迁移) ====================
NEXT_PUBLIC_COZE_API_BASE=https://api.coze.cn
NEXT_PUBLIC_COZE_CHAT_TOKEN=your_chat_token
NEXT_PUBLIC_COZE_BOT_ID=your_bot_id

# ==================== Next.js 配置 ====================
NEXT_PUBLIC_API_URL=http://localhost:3000
