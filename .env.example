# ==================== Coze API 配置 ====================
COZE_API_KEY=Bearer your_token
COZE_BOT_ID=your_bot_id
COZE_SPACE_ID=your_space_id
COZE_BASE_URL=https://api.coze.cn

# Next.js 客户端可用变量（NEXT_PUBLIC_ 前缀）
# 代码中会自动拼接 Bearer 前缀，此处只填原始 token
NEXT_PUBLIC_COZE_API_BASE=https://api.coze.cn
NEXT_PUBLIC_COZE_CHAT_TOKEN=your_chat_token
NEXT_PUBLIC_COZE_KNOWLEDGE_TOKEN=your_knowledge_token
NEXT_PUBLIC_COZE_DATASET_TOKEN=your_dataset_token
NEXT_PUBLIC_COZE_LIST_DATASETS_TOKEN=your_list_datasets_token
NEXT_PUBLIC_COZE_BOT_ID=your_bot_id
NEXT_PUBLIC_COZE_DATASET_ID=your_dataset_id
NEXT_PUBLIC_COZE_SPACE_ID=your_space_id

# ==================== 小米 mimo 大模型 ====================
OPENAI_API_KEY=your_mimo_api_key
OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=mimo-v2.5

NEXT_PUBLIC_MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
NEXT_PUBLIC_MIMO_API_KEY=your_mimo_api_key
NEXT_PUBLIC_MIMO_MODEL=mimo-v2.5

# ==================== Next.js 配置 ====================
NEXT_PUBLIC_API_URL=http://localhost:3000
CHAT_TOKEN=Bearer your_chat_token
