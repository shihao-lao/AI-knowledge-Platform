# ==================== 自建 RAG - Embedding Provider ====================
# 支持: openai | deepseek
EMBEDDING_PROVIDER=openai

# OpenAI Embedding
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# DeepSeek Embedding (当 EMBEDDING_PROVIDER=deepseek 时使用)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# ==================== 小米 mimo 大模型 ====================
# 服务端 API Route 使用（不暴露给客户端）
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_API_KEY=your_mimo_api_key
MIMO_MODEL=mimo-v2.5

# 客户端使用（lib/mimo-api.ts）
NEXT_PUBLIC_MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
NEXT_PUBLIC_MIMO_API_KEY=your_mimo_api_key
NEXT_PUBLIC_MIMO_MODEL=mimo-v2.5

# ==================== Next.js 配置 ====================
NEXT_PUBLIC_API_URL=http://localhost:3000
